# ============================================================
# kiwi-mem 环境变量配置
# ============================================================
# 复制此文件为 .env 并填入你的值
# cp .env.example .env

# ---- 必填 ----

# LLM API Key（OpenRouter / OpenAI / AIHubMix / 其他兼容 OpenAI 格式的服务商）
API_KEY=sk-your-api-key-here

# LLM API 地址
API_BASE_URL=https://openrouter.ai/api/v1/chat/completions

# ---- Docker Compose 用户可以跳过以下配置 ----
# docker compose up 会自动创建数据库并连接，无需手动配置 DATABASE_URL

# PostgreSQL 连接串（仅手动部署时需要填写）
# DATABASE_URL=postgresql://user:password@localhost:5432/kiwi_mem

# ---- 可选 ----

# 记忆系统开关（docker compose 默认开启）
MEMORY_ENABLED=true

# 默认聊天模型
DEFAULT_MODEL=anthropic/claude-sonnet-4

# 网关端口
PORT=8080

# 每次注入的最大记忆条数
MAX_MEMORIES_INJECT=15

# 记忆提取间隔（每 N 轮对话提取一次）
MEMORY_EXTRACT_INTERVAL=3

# 前端域名白名单（逗号分隔，CORS 用）
CORS_ORIGINS=*

# jieba 自定义分词词汇（逗号分隔，适合添加人名、专有名词）
JIEBA_CUSTOM_WORDS=

# OpenRouter 需要的额外请求头
EXTRA_REFERER=https://kiwi-mem.local
EXTRA_TITLE=kiwi-mem
